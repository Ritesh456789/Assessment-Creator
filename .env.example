# Environment Configuration Template
# Copy this to .env and fill in your values

# ============================================
# FRONTEND (Next.js)
# ============================================
WEB_PORT=3000

# IMPORTANT: For deployment, set these to your production URLs
# Example: NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:4001/api
NEXT_PUBLIC_WS_URL=ws://localhost:4001/ws

# ============================================
# BACKEND (Express API)
# ============================================
API_PORT=4001
NODE_ENV=development

# MongoDB Atlas Connection
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=

# Redis Connection
# Local: redis://localhost:6379
# Redis Cloud: rediss://default:password@host:port (note the 's' in rediss for SSL)
# Upstash: UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN
REDIS_URL=redis://localhost:6379

# ============================================
# AI & EXTERNAL SERVICES
# ============================================
# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# ============================================
# SECURITY & API CONFIGURATION
# ============================================
# CORS origin for API requests
# For production: CORS_ORIGIN=https://your-vercel-app.vercel.app
CORS_ORIGIN=*

# Maximum upload file size in MB
UPLOAD_MAX_MB=10

# Assessment storage: 'database' or 'memory'
ASSESSMENT_STORAGE=database

# ============================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================
# Update these for deployment:
# 1. MONGODB_URI: Keep secure in deployment secrets
# 2. REDIS_URL: Use Redis Cloud rediss:// protocol with SSL
# 3. GEMINI_API_KEY: Store in deployment platform secrets
# 4. CORS_ORIGIN: Set to your Vercel app URL
# 5. NEXT_PUBLIC_API_URL: Set to your backend URL
# 6. NEXT_PUBLIC_WS_URL: Set to your backend WebSocket URL
# 7. NODE_ENV: Set to 'production'
