{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "noEmit": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "../..",
    "baseUrl": "../..",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@core/*": ["packages/core/src/*"]
    }
  },
  "include": ["src/**/*", "../../packages/core/src/**/*"],
  "exclude": ["node_modules", "dist"]
}